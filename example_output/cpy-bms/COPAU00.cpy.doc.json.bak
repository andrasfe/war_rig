  "paragraphs": [
    {
      "paragraph_name": "COPAU0AI",
      "summary": null,
      "purpose": "This data structure defines the layout for screen input/output fields. It includes fields for transaction name (TRNNAMEL, TRNNAMEF, TRNNAMEA, TRNNAMEI), title (TITLE01L, TITLE01F, TITLE01A, TITLE01I), current date (CURDATEL, CURDATEF), selection option (SEL0005L, SEL0005F, SEL0005A, SEL0005I), amount (PAMT001L, PAMT001F, PAMT001A, PAMT001I, PAMT002L, PAMT002F, PAMT002A, PAMT002I, PAMT003L, PAMT003F, PAMT003A, PAMT003I, PAMT004L, PAMT004F, PAMT004A, PAMT004I, PAMT005L, PAMT005F, PAMT005A, PAMT005I), and error message (ERRMSGL, ERRMSGF, ERRMSGA, ERRMSGI). The structure uses a combination of COMP and PICTURE clauses to define the data types and lengths of each field. The 'L' suffix indicates the length of the field, 'F' is a single character flag, 'A' is a redefined single character flag, and 'I' is the actual data. This structure does not perform any business logic or call other paragraphs; it simply defines the data layout.",
      "called_by": [],
      "calls": [],
      "citation": [
        24,
        390
      ],
      "outgoing_calls": [],
      "incoming_calls": [],
      "is_dead_code": true,
      "dead_code_reason": "Record layout 'COPAU0AI' is never used by any program",
      "metadata": {
        "body_chunks": 8
      }
    },
    {
      "paragraph_name": "COPAU0AO",
      "summary": null,
      "purpose": "This data structure redefines the COPAU0AI structure to provide a different view of the same data. Specifically, it redefines parts of the transaction name, title, and current date fields into single-character fields (TRNNAMEC, TRNNAMEP, TRNNAMEH, TRNNAMEV, TRNNAMEO, TITLE01C, TITLE01P, TITLE01H, TITLE01V, TITLE01O, CURDATEC). This allows for easier manipulation or display of individual characters within these fields. The FILLER fields are used to skip over portions of the original COPAU0AI structure that are not being redefined. This structure does not perform any business logic or call other paragraphs; it simply provides an alternative data layout based on COPAU0AI.",
      "called_by": [],
      "calls": [],
