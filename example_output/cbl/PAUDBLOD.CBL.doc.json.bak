  "purpose": {
    "summary": "The COBOL program PAUDBLOD reads two sequential input files (INFILE1 and INFILE2), treats the records as IMS database segments (root and child), and inserts them into an IMS database. It reads records from INFILE1 into PENDING-AUTH-SUMMARY (root segment) and INFILE2 into PENDING-AUTH-DETAILS (child segment), then calls IMS functions to insert these segments into the database.",
    "business_context": "This program is likely part of a larger system dealing with pending authorizations, possibly related to financial transactions or security clearances. The program's function is to load data from sequential files into an IMS database for further processing or querying.",
    "program_type": "BATCH",
    "citations": [
      126,
      129,
      2042353
    ]
  },
