      "metadata": null
    },
    {
      "paragraph_name": "2000-EXIT",
      "summary": null,
      "purpose": "This paragraph serves as the exit point for the 2000-FIND-NEXT-AUTH-SUMMARY paragraph. It simply contains the EXIT statement, allowing control to return to the calling paragraph (MAIN-PARA). It does not perform any data manipulation, error handling, or call any other paragraphs. Its sole purpose is to provide a defined exit point for the summary record retrieval process.",
