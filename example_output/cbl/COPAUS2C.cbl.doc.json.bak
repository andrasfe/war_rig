  "purpose": {
    "summary": "COPAUS2C is a CICS COBOL DB2 program that marks an authorization message as fraudulent. It inserts a record into the CARDDEMO.AUTHFRDS table with fraud information, and if a duplicate record exists, it updates the existing record.",
    "business_context": "This program is part of the CardDemo application and is used to report fraudulent authorization attempts.",
