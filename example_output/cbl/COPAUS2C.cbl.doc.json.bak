  "paragraphs": [
    {
      "paragraph_name": "COPAUS2C",
      "summary": null,
      "purpose": "This is the main program entry point. It doesn't contain any executable logic other than calling other programs or copybooks. It declares the program ID and includes necessary copybooks such as SQLCA for DB2 communication. The program also calls CIPAUDTY and AUTHFRDS, but their purpose cannot be determined from the provided code snippet.",
      "called_by": [],
      "calls": [
        "CIPAUDTY",
        "SQLCA",
        "AUTHFRDS"
      ],
      "citation": [
        23,
        23
      ],
      "outgoing_calls": [
        {
          "target": "CIPAUDTY",
          "call_type": "includes",
          "line": 78
        },
        {
          "target": "SQLCA",
          "call_type": "includes",
          "line": 65
        },
        {
          "target": "AUTHFRDS",
          "call_type": "includes",
