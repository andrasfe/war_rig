    {
      "rule_id": "BR001",
      "description": "If the SQLCODE is zero after inserting a record into CARDDEMO.AUTHFRDS, the fraud update is considered successful.",
      "logic_summary": "Checks SQLCODE after INSERT.",
      "conditions": [
        "SQLCODE = ZERO"
      ],
