  "purpose": {
    "summary": "This COBOL program processes fraud reports and updates the CARDDEMO.AUTHFRDS table in a DB2 database. It inserts new records or updates existing ones based on the SQLCODE returned from the INSERT statement. The program is triggered by a CICS transaction.",
    "business_context": "Fraud detection and reporting within a card authorization system.",
