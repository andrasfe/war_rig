  "purpose": {
    "summary": "This CICS program displays a summary of authorizations for a given account. It retrieves authorization details from an IMS database and presents them on a screen, allowing the user to page through the authorizations and select one for further details.",
    "business_context": "This program is part of a card authorization system, allowing users to view and select authorizations for an account.",
