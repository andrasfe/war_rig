  "business_rules": [
    {
      "rule_id": "BR001",
      "description": "Account ID must be numeric and not spaces or LOW-VALUES.",
      "logic_summary": "Validates the ACCTIDI field from the input map COPAU0AI. If the field is spaces, LOW-VALUES, or non-numeric, an error message is displayed.",
      "conditions": [
        "ACCTIDI OF COPAU0AI = SPACES OR LOW-VALUES",
        "ACCTIDI OF COPAU0AI IS NOT NUMERIC"
      ],
      "citation": [
        90,
        99
      ]
    },
    {
      "rule_id": "BR002",
      "description": "If an authorization is selected, the selected value must be 'S' or 's' to proceed to the authorization details screen.",
      "logic_summary": "Checks the CDEMO-CPVS-PAU-SEL-FLG field. If it's 'S' or 's', the program transfers control to the authorization details program (CDEMO-TO-PROGRAM). Otherwise, an error message is displayed.",
      "conditions": [
        "CDEMO-CPVS-PAU-SEL-FLG NOT = SPACES AND LOW-VALUES",
        "CDEMO-CPVS-PAU-SELECTED NOT = SPACES AND LOW-VALUES",
        "CDEMO-CPVS-PAU-SEL-FLG = 'S' or 's'"
      ],
      "citation": [
        136,
        138,
        140,
        141
      ]
    },
    {
      "rule_id": "BR003",
      "description": "The program handles PF7 and PF8 keys to navigate through pages of authorization details.",
      "logic_summary": "When PF7 is pressed, the page number is decremented, and the previous page of authorizations is displayed. When PF8 is pressed, the program attempts to retrieve the next page of authorizations.",
      "conditions": [
        "EIBAID = DFHPF7",
        "EIBAID = DFHPF8"
      ],
      "citation": [
        66,
        69
      ]
    }
  ],
