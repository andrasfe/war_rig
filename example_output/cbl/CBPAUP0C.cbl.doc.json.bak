  "purpose": {
    "summary": "This COBOL batch IMS program, CBPAUP0C, deletes expired pending authorization messages from the IMS database. It reads pending authorization summary and detail segments, checks if the authorization has expired based on a configurable expiry period, and deletes the detail segment if expired. If all detail segments for a summary segment are deleted, the summary segment is also deleted.",
    "business_context": "This program is part of a card authorization system, likely used to clean up old, unused authorization requests to maintain database performance and reduce storage costs.",
    "program_type": "BATCH",
    "citations": [
      3,
      4,
      5
    ]
  },
