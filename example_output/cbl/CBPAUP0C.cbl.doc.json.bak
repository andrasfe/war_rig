        99
      ]
    },
    {
      "rule_id": "BR002",
      "description": "The program takes a checkpoint if the number of processed summary records (WS-AUTH-SMRY-PROC-CNT) exceeds the checkpoint frequency (P-CHKP-FREQ).",
      "logic_summary": "Compares WS-AUTH-SMRY-PROC-CNT to P-CHKP-FREQ.",
      "conditions": [
        "IF WS-AUTH-SMRY-PROC-CNT > P-CHKP-FREQ"
