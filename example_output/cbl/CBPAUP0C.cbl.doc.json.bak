  "purpose": {
    "summary": "The CBPAUP0C program is a batch COBOL IMS program that deletes expired pending authorization messages from the IMS database. It reads pending authorization summary and detail segments, checks if they are expired based on a configurable expiry period, and deletes the expired detail segments and summary segments if they have no remaining active details. The program also takes checkpoints periodically to ensure recoverability.",
    "business_context": "This program maintains the authorization database by removing old and irrelevant authorization records, which helps to optimize database performance and reduce storage costs.",
    "program_type": "BATCH",
    "citations": [
      3,
      247,
      262
    ]
  },
