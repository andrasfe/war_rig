  "business_rules": [
    {
      "rule_id": "BR001",
      "description": "Delete authorization detail records if they are expired.",
      "logic_summary": "Compares the authorization date with the current date and expiry days to determine if the record is expired.",
      "conditions": [
        "IF QUALIFIED-FOR-DELETE"
      ],
      "citation": [
        387,
        389
      ]
    },
    {
      "rule_id": "BR002",
      "description": "Delete authorization summary records if there are no approved or pending authorization details.",
      "logic_summary": "Checks if the approved and pending authorization counts are zero.",
      "conditions": [
        "IF PA-APPROVED-AUTH-CNT <= 0 AND PA-APPROVED-AUTH-CNT <= 0"
      ],
      "citation": [
