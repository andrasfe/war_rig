  "purpose": {
    "summary": "COPAUS1C is a CICS program that displays authorization details and allows users to mark authorizations as fraudulent. It retrieves authorization information based on account ID and authorization key, presents the data on a screen, and provides options to navigate through authorizations or report fraud.",
    "business_context": "This program is used to view and manage authorization details, specifically to identify and report fraudulent authorizations.",
