  "business_rules": [
    {
      "rule_id": "BR001",
      "description": "If the authorization response code is '00', the authorization is considered approved and 'A' is displayed on the screen with green color.",
      "logic_summary": "Checks PA-AUTH-RESP-CODE and sets AUTHRSPO and AUTHRSPC accordingly.",
      "conditions": [
        "IF PA-AUTH-RESP-CODE = '00'"
      ],
      "citation": [
        323,
        324,
        325
      ]
    },
    {
      "rule_id": "BR002",
      "description": "If the authorization response code is not '00', the authorization is considered declined and 'D' is displayed on the screen with red color.",
      "logic_summary": "Checks PA-AUTH-RESP-CODE and sets AUTHRSPO and AUTHRSPC accordingly.",
      "conditions": [
        "ELSE (PA-AUTH-RESP-CODE not = '00')"
      ],
      "citation": [
        326,
