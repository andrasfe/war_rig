  "business_rules": [
    {
      "rule_id": "BR001",
      "description": "If the authorization response code is '00', the authorization is approved, and the screen displays 'A' in green. Otherwise, it is declined, and the screen displays 'D' in red.",
      "logic_summary": "Checks PA-AUTH-RESP-CODE and sets AUTHRSPO and AUTHRSPC accordingly.",
      "conditions": [
        "IF PA-AUTH-RESP-CODE = '00'"
      ],
      "citation": [
        163,
        166
      ]
    },
    {
      "rule_id": "BR002",
      "description": "If the user presses PF5, the program marks the authorization as fraudulent or removes the fraud flag, depending on its current state.",
      "logic_summary": "Checks PA-FRAUD-CONFIRMED and sets PA-FRAUD-CONFIRMED or PA-FRAUD-REMOVED accordingly.",
      "conditions": [
        "IF PA-FRAUD-CONFIRMED"
      ],
      "citation": [
        86,
        90
      ]
    },
    {
      "rule_id": "BR003",
      "description": "If the user presses PF8, the program retrieves the next authorization record and displays it. If there are no more authorization records, a message is displayed.",
      "logic_summary": "Reads the next authorization record and populates the screen. Checks AUTHS-EOF to determine if there are more records.",
      "conditions": [
        "IF AUTHS-EOF"
      ],
      "citation": [
        132,
        136
      ]
    }
  ],
