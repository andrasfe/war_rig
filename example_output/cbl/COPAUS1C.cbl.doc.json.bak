  "business_rules": [
    {
      "rule_id": "BR001",
      "description": "If the account ID and authorization key are numeric and not spaces, read the authorization record.",
      "logic_summary": "Checks CDEMO-ACCT-ID and CDEMO-CPVD-PAU-SELECTED for valid values before reading the authorization record.",
      "conditions": [
        "IF CDEMO-ACCT-ID IS NUMERIC",
        "IF CDEMO-CPVD-PAU-SELECTED NOT = SPACES AND LOW-VALUES"
      ],
      "citation": [
        211,
        212
      ]
    },
    {
      "rule_id": "BR002",
      "description": "If the authorization is not already marked as fraudulent, mark it as fraudulent; otherwise, remove the fraud flag.",
      "logic_summary": "Toggles the PA-FRAUD-CONFIRMED flag based on its current state.",
      "conditions": [
        "IF PA-FRAUD-CONFIRMED"
      ],
      "citation": [
        236
      ]
    },
    {
      "rule_id": "BR003",
      "description": "If the authorization response code is '00', display 'A' (Approved) in green; otherwise, display 'D' (Declined) in red.",
      "logic_summary": "Sets the AUTHRSPO and AUTHRSPC fields based on PA-AUTH-RESP-CODE.",
      "conditions": [
        "IF PA-AUTH-RESP-CODE = '00'"
      ],
      "citation": [
        324
      ]
    },
    {
      "rule_id": "BR004",
      "description": "If at the end of file, display message.",
      "logic_summary": "Checks AUTHS-EOF to determine if the end of the authorization file has been reached.",
      "conditions": [
        "IF AUTHS-EOF"
      ],
      "citation": [
        281
      ]
    }
  ],
