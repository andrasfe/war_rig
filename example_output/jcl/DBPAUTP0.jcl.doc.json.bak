  "paragraphs": [
    {
      "paragraph_name": "STEPDEL",
      "summary": null,
      "purpose": "This step deletes the output dataset AWS.M2.CARDDEMO.IMSDATA.DBPAUTP0 before the unload process. It executes the utility IEFBR14 with DISP=(MOD,DELETE) to remove the dataset. The SYSPRINT DD defines the output for system messages. SYSUT1 defines the dataset to be deleted, specifying the dataset name, disposition, unit, and space allocation. If the dataset does not exist, the step will still complete successfully. This ensures that the subsequent unload step can create the dataset without encountering a dataset already exists error. No specific error handling is implemented within this step.",
      "called_by": [],
      "calls": [],
      "citation": [
        7,
        10
      ],
      "outgoing_calls": [
        {
          "target": "IEFBR14",
          "call_type": "executes",
          "line": 7
        },
        {
          "target": "AWS.M2.CARDDEMO.IMSDATA.DBPAUTP0",
          "call_type": "references",
