  "purpose": {
    "summary": "This BMS map defines the screen layout for displaying pending authorization details in the CardDemo application. It includes fields for card number, authorization details (date, time, response, code), amount, POS entry mode, source, MCC code, card expiration date, authorization type, transaction ID, match status, fraud status, and merchant details (name, ID, city, state, zip). It also provides function key options for navigation and fraud management.",
    "business_context": "This screen is used to view details of pending card authorization transactions, likely for review and potential fraud detection or resolution.",
