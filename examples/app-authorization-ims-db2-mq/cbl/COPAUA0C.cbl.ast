BLE-AMT", "line_start": 668, "line_end": 668, "attributes": {"condition": "WS-TRANSACTION-AMT > WS-AVAILABLE-AMT"}, "children": [{"type": "SET", "text": "SET DECLINE-AUTH      TO TRUE", "line_start": 669, "line_end": 669, "attributes": {}, "children": []}, {"type": "SET", "text": "SET INSUFFICIENT-FUND TO TRUE", "line_start": 670, "line_end": 670, "attributes": {}, "children": []}]}, {"type": "ELSE", "text": "ELSE", "line_start": 672, "line_end": 672, "attributes": {}, "children": [{"type": "IF", "text": "IF FOUND-ACCT-IN-MSTR", "line_start": 673, "line_end": 673, "attributes": {"condition": "FOUND-ACCT-IN-MSTR"}, "children": [{"type": "COMPUTE", "text": "COMPUTE WS-AVAILABLE-AMT = ACCT-CREDIT-LIMIT\n- ACCT-CURR-BAL", "line_start": 674, "line_end": 675, "attributes": {"target": "WS-AVAILABLE-AMT", "expression": "ACCT-CREDIT-LIMIT"}, "children": []}, {"type": "IF", "text": "IF WS-TRANSACTION-AMT > WS-AVAILABLE-AMT", "line_start": 676, "line_end": 676, "attributes": {"condition": "WS-TRANSACTION-AMT > WS-AVAILABLE-AMT"}, "children": [{"type": "SET", "text": "SET DECLINE-AUTH      TO TRUE", "line_start": 677, "line_end": 677, "attributes": {}, "children": []}, {"type": "SET", "text": "SET INSUFFICIENT-FUND TO TRUE", "line_start": 678, "line_end": 678, "attributes": {}, "children": []}]}, {"type": "ELSE", "text": "ELSE", "line_start": 680, "line_end": 680, "attributes": {}, "children": [{"type": "SET", "text": "SET DECLINE-AUTH         TO TRUE", "line_start": 681, "line_end": 681, "attributes": {}, "children": []}]}]}]}]}, {"type": "IF", "text": "IF DECLINE-AUTH", "line_start": 685, "line_end": 685, "attributes": {"condition": "DECLINE-AUTH"}, "children": [{"type": "SET", "text": "SET  AUTH-RESP-DECLINED     TO TRUE", "line_start": 686, "line_end": 686, "attributes": {}, "children": []}, {"type": "MOVE", "text": "MOVE '05'                   TO PA-RL-AUTH-RESP-CODE", "line_start": 688, "line_end": 688, "attributes": {"source": "'05'", "targets": "PA-RL-AUTH-RESP-CODE"}, 