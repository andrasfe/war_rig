{"source": "'9000'", "targets": "PA-RL-AUTH-RESP-REASON"}, "children": []}]}]}]}, {"type": "MOVE", "text": "MOVE WS-APPROVED-AMT        TO WS-APPROVED-AMT-DIS", "line_start": 720, "line_end": 720, "attributes": {"source": "WS-APPROVED-AMT", "targets": "WS-APPROVED-AMT-DIS"}, "children": []}, {"type": "STRING", "text": "STRING PA-RL-CARD-NUM         ','\nPA-RL-TRANSACTION-ID   ','\nPA-RL-AUTH-ID-CODE     ','\nPA-RL-AUTH-RESP-CODE   ','\nPA-RL-AUTH-RESP-REASON ','\nWS-APPROVED-AMT-DIS    ','\nDELIMITED BY SIZE\nINTO W02-PUT-BUFFER\nWITH POINTER WS-RESP-LENGTH\nEND-STRING", "line_start": 722, "line_end": 732, "attributes": {}, "children": []}]}, {"name": "6000-EXIT", "line_start": 734, "line_end": 735, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 735, "line_end": 735, "attributes": {}, "children": []}]}, {"name": "7100-SEND-RESPONSE", "line_start": 738, "line_end": 780, "statements": [{"type": "MOVE", "text": "MOVE MQOT-Q               TO MQOD-OBJECTTYPE OF MQM-OD-REPLY", "line_start": 741, "line_end": 741, "attributes": {"source": "MQOT-Q", "targets": "MQOD-OBJECTTYPE OF MQM-OD-REPLY"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-REPLY-QNAME       TO MQOD-OBJECTNAME OF MQM-OD-REPLY", "line_start": 742, "line_end": 742, "attributes": {"source": "WS-REPLY-QNAME", "targets": "MQOD-OBJECTNAME OF MQM-OD-REPLY"}, "children": []}, {"type": "MOVE", "text": "MOVE MQMT-REPLY           TO MQMD-MSGTYPE     OF MQM-MD-REPLY", "line_start": 744, "line_end": 744, "attributes": {"source": "MQMT-REPLY", "targets": "MQMD-MSGTYPE     OF MQM-MD-REPLY"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-SAVE-CORRELID     TO MQMD-CORRELID    OF MQM-MD-REPLY", "line_start": 745, "line_end": 745, "attributes": {"source": "WS-SAVE-CORRELID", "targets": "MQMD-CORRELID    OF MQM-MD-REPLY"}, "children": []}, {"type": "MOVE", "text": "MOVE MQMI-NONE            TO MQMD-MSGID       OF MQM-MD-REPLY", "line_start": 746, "line_end": 746, "attributes": {"source": "MQMI-NONE", "targets": "MQMD-MSGID       OF MQM-MD-REPLY"}, "children": []}, {"type": "MOVE", "text": "MOVE SPACES               TO MQMD-REPLYTOQ    OF MQM-MD-REPLY", "line_start": 747, "line_end": 747, "attributes": {"source": "SPACES", "targets": "MQMD-REPLYTOQ    OF MQM-MD-REPLY"}, "children": []}, {"type": "MOVE", "text": "MOVE SPACES               TO MQMD-REPLYTOQMGR OF MQM-MD-REPLY", "line_start": 748, "line_end": 748, "attributes": {"source": "SPACES", "targets": "MQMD-REPLYTOQMGR OF MQM-MD-REPLY"}, "children": []}, {"type": "MOVE", "text": "MOVE MQPER-NOT-PERSISTENT TO MQMD-PERSISTENCE OF MQM-MD-REPLY", "line_start": 749, "line_end": 749, "attributes": {"source": "MQPER-NOT-PERSISTENT", "targets": "MQMD-PERSISTENCE OF MQM-MD-REPLY"}, "children": []}, {"type": "MOVE", "text": "MOVE 50                   TO MQMD-EXPIRY      OF MQM-MD-REPLY", "line_start": 750, "line_end": 750, "attributes": {"source": "50", "targets": "MQMD-EXPIRY      OF MQM-MD-REPLY"}, "children": []}, {"type": "MOVE", "text": "MOVE MQFMT-STRING         TO MQMD-FORMAT      OF MQM-MD-REPLY", "line_start": 751, "line_end": 751, "attributes": {"source": "MQFMT-STRING", "targets": "MQMD-FORMAT      OF MQM-MD-REPLY"}, "children": []}, {"type": "COMPUTE", "text": "COMPUTE MQPMO-OPTIONS     =  MQPMO-NO-SYNCPOINT +\nMQPMO-DEFAULT-CONTEXT", "line_start": 753, "line_end": 754, "attributes": {"target": "MQPMO-OPTIONS", "expression": "MQPMO-NO-SYNCPOINT +"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-RESP-LENGTH       TO W02-BUFFLEN", "line_start": 756, "line_end": 756, "attributes": {"source": "WS-RESP-LENGTH", "targets": "W02-BUFFLEN"}, "children": []}, {"type": "CALL", "text": "CALL 'MQPUT1' USING W02-HCONN-REPLY\nMQM-OD-REPLY\nMQM-MD-REPLY\nMQM-PUT-MESSAGE-OPTIONS\nW02-BUFFLEN\nW02-PUT-BUFFER\nWS-COMPCODE\nWS-REASON\nEND-CALL", "line_start": 758, "line_end": 766, "attributes": {"target": "MQPUT1"}, "children": []}, {"type": "IF", "text": "IF WS-COMPCODE NOT = MQCC-OK", "line_start": 767, "line_end": 767, "