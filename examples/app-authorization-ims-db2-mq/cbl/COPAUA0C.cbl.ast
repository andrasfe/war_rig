 [{"type": "EXEC_CICS", "text": "EXEC CICS ASKTIME NOHANDLE ABSTIME(WS-ABS-TIME) END-EXEC", "line_start": 857, "line_end": 859, "attributes": {"raw_text": "EXEC CICS ASKTIME NOHANDLE ABSTIME(WS-ABS-TIME) END-EXEC"}, "children": []}, {"type": "EXEC_CICS", "text": "EXEC CICS FORMATTIME ABSTIME(WS-ABS-TIME) YYDDD(WS-CUR-DATE-X6) TIME(WS-CUR-TIME-X6) MILLISECONDS(WS-CUR-TIME-MS) END-EXEC", "line_start": 861, "line_end": 866, "attributes": {"raw_text": "EXEC CICS FORMATTIME ABSTIME(WS-ABS-TIME) YYDDD(WS-CUR-DATE-X6) TIME(WS-CUR-TIME-X6) MILLISECONDS(WS-CUR-TIME-MS) END-EXEC"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-CUR-DATE-X6(1:5)         TO WS-YYDDD", "line_start": 868, "line_end": 868, "attributes": {"source": "WS-CUR-DATE-X6(1:5)", "targets": "WS-YYDDD"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-CUR-TIME-X6              TO WS-CUR-TIME-N6", "line_start": 869, "line_end": 869, "attributes": {"source": "WS-CUR-TIME-X6", "targets": "WS-CUR-TIME-N6"}, "children": []}, {"type": "COMPUTE", "text": "COMPUTE WS-TIME-WITH-MS = (WS-CUR-TIME-N6 * 1000) +\nWS-CUR-TIME-MS", "line_start": 871, "line_end": 872, "attributes": {"target": "WS-TIME-WITH-MS", "expression": "(WS-CUR-TIME-N6 * 1000) +"}, "children": []}, {"type": "COMPUTE", "text": "COMPUTE PA-AUTH-DATE-9C = 99999 - WS-YYDDD", "line_start": 874, "line_end": 874, "attributes": {"target": "PA-AUTH-DATE-9C", "expression": "99999 - WS-YYDDD"}, "children": []}, {"type": "COMPUTE", "text": "COMPUTE PA-AUTH-TIME-9C = 999999999 - WS-TIME-WITH-MS", "line_start": 875, "line_end": 875, "attributes": {"target": "PA-AUTH-TIME-9C", "expression": "999999999 - WS-TIME-WITH-MS"}, "children": []}, {"type": "MOVE", "text": "MOVE PA-RQ-AUTH-DATE             TO PA-AUTH-ORIG-DATE", "line_start": 877, "line_end": 877, "attributes": {"source": "PA-RQ-AUTH-DATE", "targets": "PA-AUTH-ORIG-DATE"}, "children": []}, {"type": "MOVE", "text": "MOVE PA-RQ-AUTH-TIME             TO PA-AUTH-ORIG-TIME", "line_start": 878, "line_end": 87