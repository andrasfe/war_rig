{"program_id": "COPAUA0C", "paragraphs": [{"name": "MAIN-PARA", "line_start": 220, "line_end": 227, "statements": [{"type": "PERFORM_THRU", "text": "PERFORM 1000-INITIALIZE    THRU 1000-EXIT", "line_start": 222, "line_end": 222, "attributes": {"target": "1000-INITIALIZE", "thru": "1000-EXIT"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 2000-MAIN-PROCESS  THRU 2000-EXIT", "line_start": 223, "line_end": 223, "attributes": {"target": "2000-MAIN-PROCESS", "thru": "2000-EXIT"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 9000-TERMINATE     THRU 9000-EXIT", "line_start": 224, "line_end": 224, "attributes": {"target": "9000-TERMINATE", "thru": "9000-EXIT"}, "children": []}, {"type": "EXEC_CICS", "text": "EXEC CICS RETURN END-EXEC", "line_start": 226, "line_end": 227, "attributes": {"raw_text": "EXEC CICS RETURN END-EXEC."}, "children": []}]}, {"name": "1000-INITIALIZE", "line_start": 230, "line_end": 247, "statements": [{"type": "EXEC_CICS", "text": "EXEC CICS RETRIEVE INTO(MQTM) NOHANDLE END-EXEC", "line_start": 233, "line_end": 236, "attributes": {"raw_text": "EXEC CICS RETRIEVE INTO(MQTM) NOHANDLE END-EXEC"}, "children": []}, {"type": "IF", "text": "IF EIBRESP = DFHRESP(NORMAL)", "line_start": 237, "line_end": 237, "attributes": {"condition": "EIBRESP = DFHRESP(NORMAL)"}, "children": [{"type": "MOVE", "text": "MOVE MQTM-QNAME              TO WS-REQUEST-QNAME", "line_start": 238, "line_end": 238, "attributes": {"source": "MQTM-QNAME", "targets": "WS-REQUEST-QNAME"}, "children": []}, {"type": "MOVE", "text": "MOVE MQTM-TRIGGERDATA        TO WS-TRIGGER-DATA", "line_start": 239, "line_end": 239, "attributes": {"source": "MQTM-TRIGGERDATA", "targets": "WS-TRIGGER-DATA"}, "children": []}]}, {"type": "MOVE", "text": "MOVE 5000                       TO WS-WAIT-INTERVAL", "line_start": 242, "line_end": 242, "attributes": {"source": "5000", "targets": "WS-WAIT-INTERVAL"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 1100-OPEN-REQUEST-QUEUE THRU 1100-EXIT", "line_start": 244, "line_end": 244, "attributes": {"target": "1100-OPEN-REQUEST-QUEUE", "thru": "1100-EXIT"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 3100-READ-REQUEST-MQ    THRU 3100-EXIT", "line_start": 246, "line_end": 247, "attributes": {"target": "3100-READ-REQUEST-MQ", "thru": "3100-EXIT"}, "children": []}]}, {"name": "1000-EXIT", "line_start": 249, "line_end": 250, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 250, "line_end": 250, "attributes": {}, "children": []}]}, {"name": "1100-OPEN-REQUEST-QUEUE", "line_start": 255, "line_end": 284, "statements": [{"type": "MOVE", "text": "MOVE MQOT-Q             TO MQOD-OBJECTTYPE OF MQM-OD-REQUEST", "line_start": 257, "line_end": 257, "attributes": {"source": "MQOT-Q", "targets": "MQOD-OBJECTTYPE OF MQM-OD-REQUEST"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-REQUEST-QNAME   TO MQOD-OBJECTNAME OF MQM-OD-REQUEST", "line_start": 258, "line_end": 258, "attributes": {"source": "WS-REQUEST-QNAME", "targets": "MQOD-OBJECTNAME OF MQM-OD-REQUEST"}, "children": []}, {"type": "COMPUTE", "text": "COMPUTE WS-OPTIONS = MQOO-INPUT-SHARED", "line_start": 260, "line_end": 260, "attributes": {"target": "WS-OPTIONS", "expression": "MQOO-INPUT-SHARED"}, "children": []}, {"type": "CALL", "text": "CALL 'MQOPEN' USING W01-HCONN-REQUEST\nMQM-OD-REQUEST\nWS-OPTIONS\nW01-HOBJ-REQUEST\nWS-COMPCODE\nWS-REASON\nEND-CALL", "line_start": 262, "line_end": 268, "attributes": {"target": "MQOPEN"}, "children": []}, {"type": "IF", "text": "IF WS-COMPCODE = MQCC-OK", "line_start": 270, "line_end": 270, "attributes": {"condition": "WS-COMPCODE = MQCC-OK"}, "children": [{"type": "SET", "text": "SET WS-REQUEST-MQ-OPEN TO TRUE", "line_start": 271, "line_end": 271, "attributes": {}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 272, "line_end": 272, "attributes": {}, "children": [{"type": "MOVE", "text": "MOVE 'M001'          TO ERR-LOCATION", "line_start": 273, "line_end": 273, "attributes": {"source": "'M001'", "targets": "ERR-LOCATION"}, "children": []}, {"type": "SET", "text": "SET  ERR-CRITICAL    TO TRUE", "line_start": 274, "line_end": 274, "attributes": {}, "children": []}, {"type": "SET", "text": "SET  ERR-MQ          TO TRUE", "line_start": 275, "line_end": 275, "attributes": {}, "children": []}, {"type": "MOVE", "text": "MOVE WS-COMPCODE     TO WS-CODE-DISPLAY", "line_start": 276, "line_end": 276, "attributes": {"source": "WS-COMPCODE", "targets": "WS-CODE-DISPLAY"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-CODE-DISPLAY TO ERR-CODE-1", "line_start": 277, "line_end": 277, "attributes": {"source": "WS-CODE-DISPLAY", "targets": "ERR-CODE-1"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-REASON       TO WS-CODE-DISPLAY", "line_start": 278, "line_end": 278, "attributes": {"source": "WS-REASON", "targets": "WS-CODE-DISPLAY"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-CODE-DISPLAY TO ERR-CODE-2", "line_start": 279, "line_end": 279, "attributes": {"source": "WS-CODE-DISPLAY", "targets": "ERR-CODE-2"}, "children": []}, {"type": "MOVE", "text": "MOVE 'REQ MQ OPEN ERROR'\nTO ERR-MESSAGE", "line_start": 280, "line_end": 281, "attributes": {"source": "'REQ MQ OPEN ERROR'", "targets": "ERR-MESSAGE"}, "children": []}, {"type": "PERFORM", "text": "PERFORM 9500-LOG-ERROR", "line_start": 282, "line_end": 282, "attributes": {"target": "9500-LOG-ERROR"}, "children": []}]}]}]}, {"name": "1100-EXIT", "line_start": 286, "line_end": 287, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 287, "line_end": 287, "attributes": {}, "children": []}]}, {"name": "1200-SCHEDULE-PSB", "line_start": 292, "line_end": 318, "statements": [{"type": "EXEC_DLI", "text": "EXEC DLI SCHD PSB((PSB-NAME)) NODHABEND END-EXEC", "line_start": 293, "line_end": 296, "attributes": {"raw_text": "EXEC DLI SCHD PSB((PSB-NAME)) NODHABEND END-EXEC"}, "children": []}, {"type": "MOVE", "text": "MOVE DIBSTAT        TO IMS-RETURN-CODE", "line_start": 297, "line_end": 297, "attributes": {"source": "DIBSTAT", "targets": "IMS-RETURN-CODE"}, "children": []}, {"type": "IF", "text": "IF PSB-SCHEDULED-MORE-THAN-ONCE", "line_start": 298, "line_end": 298, "attributes": {"condition": "PSB-SCHEDULED-MORE-THAN-ONCE"}, "children": [{"type": "EXEC_DLI", "text": "EXEC DLI TERM END-EXEC", "line_start": 299, "line_end": 300, "attributes": {"raw_text": "EXEC DLI TERM END-EXEC"}, "children": []}, {"type": "EXEC_DLI", "text": "EXEC DLI SCHD PSB((PSB-NAME)) NODHABEND END-EXEC", "line_start": 302, "line_end": 305, "attributes": {"raw_text": "EXEC DLI SCHD PSB((PSB-NAME)) NODHABEND END-EXEC"}, "children": []}, {"type": "MOVE", "text": "MOVE DIBSTAT     TO IMS-RETURN-CODE", "line_start": 306, "line_end": 306, "attributes": {"source": "DIBSTAT", "targets": "IMS-RETURN-CODE"}, "children": []}]}, {"type": "IF", "text": "IF STATUS-OK", "line_start": 308, "line_end": 308, "attributes": {"condition": "STATUS-OK"}, "children": [{"type": "SET", "text": "SET IMS-PSB-SCHD           TO TRUE", "line_start": 309, "line_end": 309, "attributes": {}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 310, "line_end": 310, "attributes": {}, "children": [{"type": "MOVE", "text": "MOVE 'I001'                TO ERR-LOCATION", "line_start": 311, "line_end": 311, "attributes": {"source": "'I001'", "targets": "ERR-LOCATION"}, "children": []}, {"type": "SET", "text": "SET  ERR-CRITICAL          TO TRUE", "line_start": 312, "line_end": 312, "attributes": {}, "children": []}, {"type": "SET", "text": "SET  ERR-IMS               TO TRUE", "line_start": 313, "line_end": 313, "attributes": {}, "children": []}, {"type": "MOVE", "text": "MOVE IMS-RETURN-CODE       TO ERR-CODE-1", "line_start": 314, "line_end": 314, "attributes": {"source": "IMS-RETURN-CODE", "targets": "ERR-CODE-1"}, "children": []}, {"type": "MOVE", "text": "MOVE 'IMS SCHD FAILED'     TO ERR-MESSAGE", "line_start": 315, "line_end": 315, "attributes": {"source": "'IMS SCHD FAILED'", "targets": "ERR-MESSAGE"}, "children": []}, {"type": "PERFORM", "text": "PERFORM 9500-LOG-ERROR", "line_start": 316, "line_end": 316, "attributes": {"target": "9500-LOG-ERROR"}, "children": []}]}]}]}, {"name": "1200-EXIT", "line_start": 319, "line_end": 321, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 320, "line_end": 321, "attributes": {}, "children": []}]}, {"name": "2000-MAIN-PROCESS", "line_start": 323, "line_end": 345, "statements": [{"type": "PERFORM_INLINE", "text": "PERFORM UNTIL NO-MORE-MSG-AVAILABLE OR WS-LOOP-END", "line_start": 326, "line_end": 326, "attributes": {"condition": "NO-MORE-MSG-AVAILABLE OR WS-LOOP-END"}, "children": [{"type": "PERFORM_THRU", "text": "PERFORM 2100-EXTRACT-REQUEST-MSG THRU 2100-EXIT", "line_start": 328, "line_end": 328, "attributes": {"target": "2100-EXTRACT-REQUEST-MSG", "thru": "2100-EXIT"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 5000-PROCESS-AUTH        THRU 5000-EXIT", "line_start": 330, "line_end": 330, "attributes": {"target": "5000-PROCESS-AUTH", "thru": "5000-EXIT"}, "children": []}, {"type": "ADD", "text": "ADD 1                            TO WS-MSG-PROCESSED", "line_start": 332, "line_end": 332, "attributes": {}, "children": []}, {"type": "EXEC_CICS", "text": "EXEC CICS SYNCPOINT END-EXEC", "line_start": 334, "line_end": 336, "attributes": {"raw_text": "EXEC CICS SYNCPOINT END-EXEC"}, "children": []}, {"type": "SET", "text": "SET IMS-PSB-NOT-SCHD            TO TRUE", "line_start": 337, "line_end": 337, "attributes": {}, "children": []}, {"type": "IF", "text": "IF WS-MSG-PROCESSED > WS-REQSTS-PROCESS-LIMIT", "line_start": 339, "line_end": 339, "attributes": {"condition": "WS-MSG-PROCESSED > WS-REQSTS-PROCESS-LIMIT"}, "children": [{"type": "SET", "text": "SET  WS-LOOP-END             TO TRUE", "line_start": 340, "line_end": 340, "attributes": {}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 341, "line_end": 341, "attributes": {}, "children": [{"type": "PERFORM_THRU", "text": "PERFORM 3100-READ-REQUEST-MQ THRU 3100-EXIT", "line_start": 342, "line_end": 342, "attributes": {"target": "3100-READ-REQUEST-MQ", "thru": "3100-EXIT"}, "children": []}]}]}]}]}, {"name": "2000-EXIT", "line_start": 347, "line_end": 348, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 348, "line_end": 348, "attributes": {}, "children": []}]}, {"name": "2100-EXTRACT-REQUEST-MSG", "line_start": 351, "line_end": 380, "statements": [{"type": "UNSTRING", "text": "UNSTRING W01-GET-BUFFER(1:W01-DATALEN)\nDELIMITED BY ','\nINTO PA-RQ-AUTH-DATE\nPA-RQ-AUTH-TIME\nPA-RQ-CARD-NUM\nPA-RQ-AUTH-TYPE\nPA-RQ-CARD-EXPIRY-DATE\nPA-RQ-MESSAGE-TYPE\nPA-RQ-MESSAGE-SOURCE\nPA-RQ-PROCESSING-CODE\nWS-TRANSACTION-AMT-AN\nPA-RQ-MERCHANT-CATAGORY-CODE\nPA-RQ-ACQR-COUNTRY-CODE\nPA-RQ-POS-ENTRY-MODE\nPA-RQ-MERCHANT-ID\nPA-RQ-MERCHANT-NAME\nPA-RQ-MERCHANT-CITY\nPA-RQ-MERCHANT-STATE\nPA-RQ-MERCHANT-ZIP\nPA-RQ-TRANSACTION-ID\nEND-UNSTRING", "line_start": 354, "line_end": 374, "attributes": {}, "children": []}, {"type": "COMPUTE", "text": "COMPUTE PA-RQ-TRANSACTION-AMT =\nFUNCTION NUMVAL(WS-TRANSACTION-AMT-AN)", "line_start": 376, "line_end": 377, "attributes": {"target": "PA-RQ-TRANSACTION-AMT", "expression": "FUNCTION NUMVAL(WS-TRANSACTION-AMT-AN)"}, "children": []}, {"type": "MOVE", "text": "MOVE PA-RQ-TRANSACTION-AMT  TO WS-TRANSACTION-AMT", "line_start": 379, "line_end": 380, "attributes": {"source": "PA-RQ-TRANSACTION-AMT", "targets": "WS-TRANSACTION-AMT"}, "children": []}]}, {"name": "2100-EXIT", "line_start": 382, "line_end": 383, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 383, "line_end": 383, "attributes": {}, "children": []}]}, {"name": "3100-READ-REQUEST-MQ", "line_start": 386, "line_end": 432, "statements": [{"type": "COMPUTE", "text": "COMPUTE MQGMO-OPTIONS  =  MQGMO-NO-SYNCPOINT + MQGMO-WAIT\n+  MQGMO-CONVERT\n+  MQGMO-FAIL-IF-QUIESCING", "line_start": 389, "line_end": 391, "attributes": {"target": "MQGMO-OPTIONS", "expression": "MQGMO-NO-SYNCPOINT + MQGMO-WAIT"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-WAIT-INTERVAL      TO MQGMO-WAITINTERVAL", "line_start": 393, "line_end": 393, "attributes": {"source": "WS-WAIT-INTERVAL", "targets": "MQGMO-WAITINTERVAL"}, "children": []}, {"type": "MOVE", "text": "MOVE MQMI-NONE             TO MQMD-MSGID    OF MQM-MD-REQUEST", "line_start": 395, "line_end": 395, "attributes": {"source": "MQMI-NONE", "targets": "MQMD-MSGID    OF MQM-MD-REQUEST"}, "children": []}, {"type": "MOVE", "text": "MOVE MQCI-NONE             TO MQMD-CORRELID OF MQM-MD-REQUEST", "line_start": 396, "line_end": 396, "attributes": {"source": "MQCI-NONE", "targets": "MQMD-CORRELID OF MQM-MD-REQUEST"}, "children": []}, {"type": "MOVE", "text": "MOVE MQFMT-STRING          TO MQMD-FORMAT   OF MQM-MD-REQUEST", "line_start": 397, "line_end": 397, "attributes": {"source": "MQFMT-STRING", "targets": "MQMD-FORMAT   OF MQM-MD-REQUEST"}, "children": []}, {"type": "MOVE", "text": "MOVE LENGTH OF W01-GET-BUFFER TO W01-BUFFLEN", "line_start": 398, "line_end": 398, "attributes": {"source": "LENGTH OF W01-GET-BUFFER", "targets": "W01-BUFFLEN"}, "children": []}, {"type": "CALL", "text": "CALL 'MQGET' USING W01-HCONN-REQUEST\nW01-HOBJ-REQUEST\nMQM-MD-REQUEST\nMQM-GET-MESSAGE-OPTIONS\nW01-BUFFLEN\nW01-GET-BUFFER\nW01-DATALEN\nWS-COMPCODE\nWS-REASON\nEND-CALL", "line_start": 400, "line_end": 409, "attributes": {"target": "MQGET"}, "children": []}, {"type": "IF", "text": "IF WS-COMPCODE = MQCC-OK", "line_start": 410, "line_end": 410, "attributes": {"condition": "WS-COMPCODE = MQCC-OK"}, "children": [{"type": "MOVE", "text": "MOVE MQMD-CORRELID OF MQM-MD-REQUEST\nTO WS-SAVE-CORRELID", "line_start": 411, "line_end": 412, "attributes": {"source": "MQMD-CORRELID OF MQM-MD-REQUEST", "targets": "WS-SAVE-CORRELID"}, "children": []}, {"type": "MOVE", "text": "MOVE MQMD-REPLYTOQ OF MQM-MD-REQUEST\nTO WS-REPLY-QNAME", "line_start": 413, "line_end": 414, "attributes": {"source": "MQMD-REPLYTOQ OF MQM-MD-REQUEST", "targets": "WS-REPLY-QNAME"}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 415, "line_end": 415, "attributes": {}, "children": [{"type": "IF", "text": "IF WS-REASON = MQRC-NO-MSG-AVAILABLE", "line_start": 416, "line_end": 416, "attributes": {"condition": "WS-REASON = MQRC-NO-MSG-AVAILABLE"}, "children": [{"type": "SET", "text": "SET NO-MORE-MSG-AVAILABLE TO TRUE", "line_start": 417, "line_end": 417, "attributes": {}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 418, "line_end": 418, "attributes": {}, "children": [{"type": "MOVE", "text": "MOVE 'M003'                TO ERR-LOCATION", "line_start": 419, "line_end": 419, "attributes": {"source": "'M003'", "targets": "ERR-LOCATION"}, "children": []}, {"type": "SET", "text": "SET  ERR-CRITICAL          TO TRUE", "line_start": 420, "line_end": 420, "attributes": {}, "children": []}, {"type": "SET", "text": "SET  ERR-CICS              TO TRUE", "line_start": 421, "line_end": 421, "attributes": {}, "children": []}, {"type": "MOVE", "text": "MOVE WS-COMPCODE           TO WS-CODE-DISPLAY", "line_start": 422, "line_end": 422, "attributes": {"source": "WS-COMPCODE", "targets": "WS-CODE-DISPLAY"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-CODE-DISPLAY       TO ERR-CODE-1", "line_start": 423, "line_end": 423, "attributes": {"source": "WS-CODE-DISPLAY", "targets": "ERR-CODE-1"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-REASON             TO WS-CODE-DISPLAY", "line_start": 424, "line_end": 424, "attributes": {"source": "WS-REASON", "targets": "WS-CODE-DISPLAY"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-CODE-DISPLAY       TO ERR-CODE-2", "line_start": 425, "line_end": 425, "attributes": {"source": "WS-CODE-DISPLAY", "targets": "ERR-CODE-2"}, "children": []}, {"type": "MOVE", "text": "MOVE 'FAILED TO READ REQUEST MQ'\nTO ERR-MESSAGE", "line_start": 426, "line_end": 427, "attributes": {"source": "'FAILED", "targets": "READ REQUEST MQ'"}, "children": []}, {"type": "MOVE", "tex