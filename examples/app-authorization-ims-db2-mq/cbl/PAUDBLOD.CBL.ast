{"program_id": "PAUDBLOD", "paragraphs": [{"name": "MAIN-PARA", "line_start": 171, "line_end": 187, "statements": [{"type": "UNKNOWN", "text": "ENTRY 'DLITCBL'                 USING PAUTBPCB", "line_start": 171, "line_end": 171, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'STARTING PAUDBLOD'", "line_start": 173, "line_end": 173, "attributes": {}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 1000-INITIALIZE                THRU 1000-EXIT", "line_start": 175, "line_end": 175, "attributes": {"target": "1000-INITIALIZE", "thru": "1000-EXIT"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 2000-READ-ROOT-SEG-FILE        THRU 2000-EXIT\nUNTIL   END-ROOT-SEG-FILE  = 'Y'", "line_start": 177, "line_end": 178, "attributes": {"target": "2000-READ-ROOT-SEG-FILE", "thru": "2000-EXIT"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 3000-READ-CHILD-SEG-FILE       THRU 3000-EXIT\nUNTIL   END-CHILD-SEG-FILE = 'Y'", "line_start": 180, "line_end": 181, "attributes": {"target": "3000-READ-CHILD-SEG-FILE", "thru": "3000-EXIT"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 4000-FILE-CLOSE THRU 4000-EXIT", "line_start": 183, "line_end": 183, "attributes": {"target": "4000-FILE-CLOSE", "thru": "4000-EXIT"}, "children": []}, {"type": "GOBACK", "text": "GOBACK", "line_start": 187, "line_end": 187, "attributes": {}, "children": []}]}, {"name": "1000-INITIALIZE", "line_start": 193, "line_end": 215, "statements": [{"type": "ACCEPT", "text": "ACCEPT CURRENT-DATE     FROM DATE", "line_start": 193, "line_end": 193, "attributes": {}, "children": []}, {"type": "ACCEPT", "text": "ACCEPT CURRENT-YYDDD    FROM DAY", "line_start": 194, "line_end": 194, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY '*-------------------------------------*'", "line_start": 196, "line_end": 196, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'TODAYS DATE            :' CURRENT-DATE", "line_start