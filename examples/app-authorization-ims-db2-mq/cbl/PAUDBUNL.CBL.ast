{"program_id": "PAUDBUNL", "paragraphs": [{"name": "MAIN-PARA", "line_start": 157, "line_end": 170, "statements": [{"type": "UNKNOWN", "text": "ENTRY 'DLITCBL'                 USING PAUTBPCB", "line_start": 158, "line_end": 158, "attributes": {}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 1000-INITIALIZE                THRU 1000-EXIT", "line_start": 161, "line_end": 161, "attributes": {"target": "1000-INITIALIZE", "thru": "1000-EXIT"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 2000-FIND-NEXT-AUTH-SUMMARY    THRU 2000-EXIT\nUNTIL   WS-END-OF-ROOT-SEG = 'Y'", "line_start": 163, "line_end": 164, "attributes": {"target": "2000-FIND-NEXT-AUTH-SUMMARY", "thru": "2000-EXIT"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 4000-FILE-CLOSE THRU 4000-EXIT", "line_start": 166, "line_end": 166, "attributes": {"target": "4000-FILE-CLOSE", "thru": "4000-EXIT"}, "children": []}, {"type": "GOBACK", "text": "GOBACK", "line_start": 170, "line_end": 170, "attributes": {}, "children": []}]}, {"name": "1000-INITIALIZE", "line_start": 173, "line_end": 200, "statements": [{"type": "ACCEPT", "text": "ACCEPT CURRENT-DATE     FROM DATE", "line_start": 176, "line_end": 176, "attributes": {}, "children": []}, {"type": "ACCEPT", "text": "ACCEPT CURRENT-YYDDD    FROM DAY", "line_start": 177, "line_end": 177, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'STARTING PROGRAM PAUDBUNL::'", "line_start": 180, "line_end": 180, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY '*-------------------------------------*'", "line_start": 181, "line_end": 181, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'TODAYS DATE            :' CURRENT-DATE", "line_start": 182, "line_end": 182, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY ' '", "line_start": 183, "line_end": 185, "attributes": {}, "children": []}, {"type": "OPEN", "text": "OPEN OUTPUT OPFILE1", "line_start": 18