{"program_id": "DBUNLDGS", "paragraphs": [{"name": "MAIN-PARA", "line_start": 164, "line_end": 179, "statements": [{"type": "UNKNOWN", "text": "ENTRY 'DLITCBL'                 USING PAUTBPCB\nPASFLPCB\nPADFLPCB", "line_start": 165, "line_end": 167, "attributes": {}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 1000-INITIALIZE                THRU 1000-EXIT", "line_start": 170, "line_end": 170, "attributes": {"target": "1000-INITIALIZE", "thru": "1000-EXIT"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 2000-FIND-NEXT-AUTH-SUMMARY    THRU 2000-EXIT\nUNTIL   WS-END-OF-ROOT-SEG = 'Y'", "line_start": 172, "line_end": 173, "attributes": {"target": "2000-FIND-NEXT-AUTH-SUMMARY", "thru": "2000-EXIT"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 4000-FILE-CLOSE THRU 4000-EXIT", "line_start": 175, "line_end": 175, "attributes": {"target": "4000-FILE-CLOSE", "thru": "4000-EXIT"}, "children": []}, {"type": "GOBACK", "text": "GOBACK", "line_start": 179, "line_end": 179, "attributes": {}, "children": []}]}, {"name": "1000-INITIALIZE", "line_start": 182, "line_end": 194, "statements": [{"type": "ACCEPT", "text": "ACCEPT CURRENT-DATE     FROM DATE", "line_start": 185, "line_end": 185, "attributes": {}, "children": []}, {"type": "ACCEPT", "text": "ACCEPT CURRENT-YYDDD    FROM DAY", "line_start": 186, "line_end": 186, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'STARTING PROGRAM DBUNLDGS::'", "line_start": 189, "line_end": 189, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY '*-------------------------------------*'", "line_start": 190, "line_end": 190, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'TODAYS DATE            :' CURRENT-DATE", "line_start": 191, "line_end": 191, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY ' '", "line_start": 192, "line_end": 194, "attributes": {}, "children": []}]}, {"name": "1000-EXIT", "line_start": 212, "