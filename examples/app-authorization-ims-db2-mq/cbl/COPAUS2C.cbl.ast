{"program_id": "COPAUS2C", "paragraphs": [{"name": "MAIN-PARA", "line_start": 91, "line_end": 220, "statements": [{"type": "EXEC_CICS", "text": "EXEC CICS ASKTIME NOHANDLE ABSTIME(WS-ABS-TIME) NOHANDLE END-EXEC", "line_start": 91, "line_end": 94, "attributes": {"raw_text": "EXEC CICS ASKTIME NOHANDLE ABSTIME(WS-ABS-TIME) NOHANDLE END-EXEC"}, "children": []}, {"type": "EXEC_CICS", "text": "EXEC CICS FORMATTIME ABSTIME(WS-ABS-TIME) MMDDYY(WS-CUR-DATE) DATESEP NOHANDLE END-EXEC", "line_start": 95, "line_end": 100, "attributes": {"raw_text": "EXEC CICS FORMATTIME ABSTIME(WS-ABS-TIME) MMDDYY(WS-CUR-DATE) DATESEP NOHANDLE END-EXEC"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-CUR-DATE       TO PA-FRAUD-RPT-DATE", "line_start": 101, "line_end": 101, "attributes": {"source": "WS-CUR-DATE", "targets": "PA-FRAUD-RPT-DATE"}, "children": []}, {"type": "MOVE", "text": "MOVE PA-AUTH-ORIG-DATE(1:2) TO WS-AUTH-YY", "line_start": 103, "line_end": 103, "attributes": {"source": "PA-AUTH-ORIG-DATE(1:2)", "targets": "WS-AUTH-YY"}, "children": []}, {"type": "MOVE", "text": "MOVE PA-AUTH-ORIG-DATE(3:2) TO WS-AUTH-MM", "line_start": 104, "line_end": 104, "attributes": {"source": "PA-AUTH-ORIG-DATE(3:2)", "targets": "WS-AUTH-MM"}, "children": []}, {"type": "MOVE", "text": "MOVE PA-AUTH-ORIG-DATE(5:2) TO WS-AUTH-DD", "line_start": 105, "line_end": 105, "attributes": {"source": "PA-AUTH-ORIG-DATE(5:2)", "targets": "WS-AUTH-DD"}, "children": []}, {"type": "COMPUTE", "text": "COMPUTE WS-AUTH-TIME = 999999999 - PA-AUTH-TIME-9C", "line_start": 107, "line_end": 107, "attributes": {"target": "WS-AUTH-TIME", "expression": "999999999 - PA-AUTH-TIME-9C"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-AUTH-TIME-AN(1:2) TO WS-AUTH-HH", "line_start": 108, "line_end": 108, "attributes": {"source": "WS-AUTH-TIME-AN(1:2)", "targets": "WS-AUTH-HH"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-AUTH-TIME-AN(3:2) TO WS-AUTH-MI", "line_start": 109, "line_end": 109, "attributes": {"source": "W