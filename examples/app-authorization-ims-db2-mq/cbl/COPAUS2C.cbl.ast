"source": "PA-MERCHANT-NAME", "targets": "MERCHANT-NAME-TEXT"}, "children": []}, {"type": "MOVE", "text": "MOVE PA-MERCHANT-CITY     TO MERCHANT-CITY", "line_start": 132, "line_end": 132, "attributes": {"source": "PA-MERCHANT-CITY", "targets": "MERCHANT-CITY"}, "children": []}, {"type": "MOVE", "text": "MOVE PA-MERCHANT-STATE    TO MERCHANT-STATE", "line_start": 133, "line_end": 133, "attributes": {"source": "PA-MERCHANT-STATE", "targets": "MERCHANT-STATE"}, "children": []}, {"type": "MOVE", "text": "MOVE PA-MERCHANT-ZIP      TO MERCHANT-ZIP", "line_start": 134, "line_end": 134, "attributes": {"source": "PA-MERCHANT-ZIP", "targets": "MERCHANT-ZIP"}, "children": []}, {"type": "MOVE", "text": "MOVE PA-TRANSACTION-ID    TO TRANSACTION-ID", "line_start": 135, "line_end": 135, "attributes": {"source": "PA-TRANSACTION-ID", "targets": "TRANSACTION-ID"}, "children": []}, {"type": "MOVE", "text": "MOVE PA-MATCH-STATUS      TO MATCH-STATUS", "line_start": 136, "line_end": 136, "attributes": {"source": "PA-MATCH-STATUS", "targets": "MATCH-STATUS"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-FRD-ACTION        TO AUTH-FRAUD", "line_start": 137, "line_end": 137, "attributes": {"source": "WS-FRD-ACTION", "targets": "AUTH-FRAUD"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-ACCT-ID           TO ACCT-ID", "line_start": 138, "line_end": 138, "attributes": {"source": "WS-ACCT-ID", "targets": "ACCT-ID"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-CUST-ID           TO CUST-ID", "line_start": 139, "line_end": 139, "attributes": {"source": "WS-CUST-ID", "targets": "CUST-ID"}, "children": []}, {"type": "EXEC_SQL", "text": "EXEC SQL INSERT INTO CARDDEMO.AUTHFRDS (CARD_NUM ,AUTH_TS ,AUTH_TYPE ,CARD_EXPIRY_DATE ,MESSAGE_TYPE ,MESSAGE_SOURCE ,AUTH_ID_CODE ,AUTH_RESP_CODE ,AUTH_RESP_REASON ,PROCESSING_CODE ,TRANSACTION_AMT ,APPROVED_AMT ,MERCHANT_CATAGORY_CODE ,ACQR_COUNTRY_CODE ,POS_ENTRY_MODE ,MERCHANT_ID ,MERCHANT_NAME ,MERCHANT_CITY ,MERCHANT_STATE ,MERCHANT_ZIP ,TRANSACTION_ID ,MATCH_STATUS ,AUTH_FRAUD ,FRAUD_RPT_DATE ,ACCT_ID ,CUST_ID) VALUES ( :CARD-NUM ,TIMESTAMP_FORMAT (:AUTH-TS, 'YY-MM-DD HH24.MI.SSNNNNNN') ,:AUTH-TYPE ,:CARD-EXPIRY-DATE ,:MESSAGE-TYPE ,:MESSAGE-SOURCE ,:AUTH-ID-CODE ,:AUTH-RESP-CODE ,:AUTH-RESP-REASON ,:PROCESSING-CODE ,:TRANSACTION-AMT ,:APPROVED-AMT ,:MERCHANT-CATAGORY-CODE ,:ACQR-COUNTRY-CODE ,:POS-ENTRY-MODE ,:MERCHANT-ID ,:MERCHANT-NAME ,:MERCHANT-CITY ,:MERCHANT-STATE ,:MERCHANT-ZIP ,:TRANSACTION-ID ,:MATCH-STATUS ,:AUTH-FRAUD ,CURRENT DATE ,:ACCT-ID ,:CUST-ID ) END-EXEC", "line_start": 141, "line_end": 198, "attributes": {"raw_text": "EXEC SQL INSERT INTO CARDDEMO.AUTHFRDS (CARD_NUM ,AUTH_TS ,AUTH_TYPE ,CARD_EXPIRY_DATE ,MESSAGE_TYPE ,MESSAGE_SOURCE ,AUTH_ID_CODE ,AUTH_RESP_CODE ,AUTH_RESP_REASON ,PROCESSING_CODE ,TRANSACTION_AMT ,APPROVED_AMT ,MERCHANT_CATAGORY_CODE ,ACQR_COUNTRY_CODE ,POS_ENTRY_MODE ,MERCHANT_ID ,MERCHANT_NAME ,MERCHANT_CITY ,MERCHANT_STATE ,MERCHANT_ZIP ,TRANSACTION_ID ,MATCH_STATUS ,AUTH_FRAUD ,FRAUD_RPT_DATE ,ACCT_ID ,CUST_ID) VALUES ( :CARD-NUM ,TIMESTAMP_FORMAT (:AUTH-TS, 'YY-MM-DD HH24.MI.SSNNNNNN') ,:AUTH-TYPE ,:CARD-EXPIRY-DATE ,:MESSAGE-TYPE ,:MESSAGE-SOURCE ,:AUTH-ID-CODE ,:AUTH-RESP-CODE ,:AUTH-RESP-REASON ,:PROCESSING-CODE ,:TRANSACTION-AMT ,:APPROVED-AMT ,:MERCHANT-CATAGORY-CODE ,:ACQR-COUNTRY-CODE ,:POS-ENTRY-MODE ,:MERCHANT-ID ,:MERCHANT-NAME ,:MERCHANT-CITY ,:MERCHANT-STATE ,:MERCHANT-ZIP ,:TRANSACTION-ID ,:MATCH-STATUS ,:AUTH-FRAUD ,CURRENT DATE ,:ACCT-ID ,:CUST-ID ) END-EXEC"}, "children": []}, {"type": "IF", "text": "IF SQLCODE = ZERO", "line_start": 199, "line_end": 199, "attributes": {"condition": "SQLCODE = ZERO"}, "children": [{"type": "SET", "text": "SET WS-FRD-UPDT-SUCCESS TO TRUE", "line_start": 200, "line_end": 200, "attributes": {}, "children": []}, {"type": "MOVE", "text": "MOVE 'ADD SUCCESS'      TO WS-FRD-ACT-MSG", "line_start": 201, "line_end": 201, "attributes": {"source": "'ADD SUCCESS'", "targets": "WS-FRD-ACT-MSG"}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 202, "line_end": 202, "attributes": {}, "children": [{"type": "IF", "text": "IF SQLCODE = -803", "line_start": 203, "line_end": 203, "attributes": {"condition": "SQLCODE = -803"}, "children": [{"type": "PERFORM", "text": "PERFORM FRAUD-UPDATE", "line_start": 204, "line_end": 204, "attributes": {"target": "FRAUD-UPDATE"}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 205, "line_end": 205, "attributes": {}, "children": [{"type": "SET", "text": "SET WS-FRD-UPDT-FAILED  TO TRUE", "line_start": 206, "line_end": 206, "attributes": {}, "children": []}, {"type": "MOVE", "text": "MOVE SQLCODE            TO WS-SQLCODE", "line_start": 208, "line_end": 208, "attributes": {"source": "SQLCODE", "targets": "WS-SQLCODE"}, "children": []}, {"type": "MOVE", "text": "MOVE SQLSTATE           TO WS-SQLSTATE", "line_start": 209, "line_end": 209, "attributes": {"source": "SQLSTATE", "targets": "WS-SQLSTATE"}, "children": []}, {"type": "STRING", "text": "STRING ' SYSTEM ERROR DB2: CODE:' WS-SQLCODE\n', STATE: ' WS-SQLSTATE   DELIMITED BY SIZE\nINTO WS-FRD-ACT-MSG\nEND-STRING", "line_start": 211, "line_end": 214, "attributes": {}, "children": []}]}]}]}]}, {"type": "EXEC_CICS", "text": "EXEC CICS RETURN END-EXEC", "line_start": 218, "line_end": 219, "attributes": {"raw_text": "EXEC CICS RETURN END-EXEC"}, "children": []}, {"type": "UNKNOWN", "text": "", "line_start": 220, "line_end": 220, "attributes": {}, "children": []}]}, {"name": "FRAUD-UPDATE", "line_start": 222, "line_end": 244, "statements": [{"type": "EXEC_SQL", "text": "EXEC SQL UPDATE CARDDEMO.AUTHFRDS SET   AUTH_FRAUD     = :AUTH-FRAUD, FRAUD_RPT_DATE = CURRENT DATE WHERE CARD_NUM = :CARD-NUM AND AUTH_TS  = TIMESTAMP_FORMAT (:AUTH-TS, 'YY-MM-DD HH24.MI.SSNNNNNN') END-EXEC", "line_start": 222, "line_end": 229, "attributes": {"raw_text": "EXEC SQL UPDATE CARDDEMO.AUTHFRDS SET   AUTH_FRAUD     = :AUTH-FRAUD, FRAUD_RPT_DATE = CURRENT DATE WHERE CARD_NUM = :CARD-NUM AND AUTH_TS  = TIMESTAMP_FORMAT (:AUTH-TS, 'YY-MM-DD HH24.MI.SSNNNNNN') END-EXEC"}, "children": []}, {"type": "IF", "text": "IF SQLCODE = ZERO", "line_start": 230, "line_end": 230, "attributes": {"condition": "SQLCODE = ZERO"}, "children": [{"type": "SET", "text": "SET WS-FRD-UPDT-SUCCESS TO TRUE", "line_start": 231, "line_end": 231, "attributes": {}, "children": []}, {"type": "MOVE", "text": "MOVE 'UPDT SUCCESS'     TO WS-FRD-ACT-MSG", "line_start": 232, "line_end": 232, "attributes": {"source": "'UPDT SUCCESS'", "targets": "WS-FRD-ACT-MSG"}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 233, "line_end": 233, "attributes": {}, "children": [{"type": "SET", "text": "SET WS-FRD-UPDT-FAILED  TO TRUE", "line_start": 234, "line_end": 234, "attributes": {}, "children": []}, {"type": "MOVE", "text": "MOVE SQLCODE            TO WS-SQLCODE", "line_start": 236, "line_end": 236, "attributes": {"source": "SQLCODE", "targets": "WS-SQLCODE"}, "children": []}, {"type": "MOVE", "text": "MOVE SQLSTATE           TO WS-SQLSTATE", "line_start": 237, "line_end": 237, "attributes": {"source": "SQLSTATE", "targets": "WS-SQLSTATE"}, "children": []}, {"type": "STRING", "text": "STRING ' UPDT ERROR DB2: CODE:' WS-SQLCODE\n', STATE: ' WS-SQLSTATE   DELIMITED BY SIZE\nINTO WS-FRD-ACT-MSG\nEND-STRING", "line_start": 239, "line_end": 242, "attributes": {}, "children": []}]}]}]}]}