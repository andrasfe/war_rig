ATE-HEADER-INFO"}, "children": []}, {"type": "MOVE", "text": "MOVE WS-MESSAGE TO ERRMSGO OF COPAU1AO", "line_start": 377, "line_end": 377, "attributes": {"source": "WS-MESSAGE", "targets": "ERRMSGO OF COPAU1AO"}, "children": []}, {"type": "MOVE", "text": "MOVE -1       TO CARDNUML", "line_start": 378, "line_end": 378, "attributes": {"source": "-1", "targets": "CARDNUML"}, "children": []}, {"type": "IF", "text": "IF SEND-ERASE-YES", "line_start": 380, "line_end": 380, "attributes": {"condition": "SEND-ERASE-YES"}, "children": [{"type": "EXEC_CICS", "text": "EXEC CICS SEND MAP('COPAU1A') MAPSET('COPAU01') FROM(COPAU1AO) ERASE CURSOR END-EXEC", "line_start": 381, "line_end": 387, "attributes": {"raw_text": "EXEC CICS SEND MAP('COPAU1A') MAPSET('COPAU01') FROM(COPAU1AO) ERASE CURSOR END-EXEC"}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 388, "line_end": 388, "attributes": {}, "children": [{"type": "EXEC_CICS", "text": "EXEC CICS SEND MAP('COPAU1A') MAPSET('COPAU01') FROM(COPAU1AO) CURSOR END-EXEC", "line_start": 389, "line_end": 394, "attributes": {"raw_text": "EXEC CICS SEND MAP('COPAU1A') MAPSET('COPAU01') FROM(COPAU1AO) CURSOR END-EXEC"}, "children": []}]}]}]}, {"name": "RECEIVE-AUTHVIEW-SCREEN", "line_start": 398, "line_end": 406, "statements": [{"type": "EXEC_CICS", "text": "EXEC CICS RECEIVE MAP('COPAU1A') MAPSET('COPAU01') INTO(COPAU1AI) NOHANDLE END-EXEC", "line_start": 400, "line_end": 405, "attributes": {"raw_text": "EXEC CICS RECEIVE MAP('COPAU1A') MAPSET('COPAU01') INTO(COPAU1AI) NOHANDLE END-EXEC"}, "children": []}, {"type": "UNKNOWN", "text": "", "line_start": 406, "line_end": 406, "attributes": {}, "children": []}]}, {"name": "POPULATE-HEADER-INFO", "line_start": 409, "line_end": 429, "statements": [{"type": "MOVE", "text": "MOVE FUNCTION CURRENT-DATE  TO WS-CURDATE-DATA", "line_start": 411, "line_end": 411, "attributes": {"source": "FUNCTION CURRENT-DATE", "targets": "WS-CURDATE-DATA"}, "children": []}, {"type": "MOVE", "text": "MOVE