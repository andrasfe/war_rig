{"program_id":"PROLEAP_PP_N36KOJ1E","paragraphs":[{"name":"MAIN-PARA","line_start":593,"line_end":642,"statements":[{"type":"SET","text":"SET ERR-FLG-OFF TO TRUE","line_start":595,"line_end":595,"attributes":{},"children":[]},{"type":"SET","text":"SET SEND-ERASE-YES TO TRUE","line_start":596,"line_end":596,"attributes":{},"children":[]},{"type":"MOVE","text":"MOVE SPACES TO WS-MESSAGE ERRMSGO OF COPAU1AO","line_start":598,"line_end":599,"attributes":{"source":"SPACES","targets":"WS-MESSAGE, ERRMSGO"},"children":[]},{"type":"IF","text":"IF EIBCALEN = 0 INITIALIZE CARDDEMO-COMMAREA MOVE WS-PGM-AUTH-SMRY TO CDEMO-TO-PROGRAM PERFORM RETURN-TO-PREV-SCREEN ELSE MOVE DFHCOMMAREA(1:EIBCALEN) TO CARDDEMO-COMMAREA MOVE SPACES TO CDEMO-CPVD...","line_start":601,"line_end":636,"attributes":{"condition":"EIBCALEN = 0"},"children":[{"type":"INITIALIZE","text":"INITIALIZE CARDDEMO-COMMAREA","line_start":602,"line_end":602,"attributes":{},"children":[]},{"type":"MOVE","text":"MOVE WS-PGM-AUTH-SMRY TO CDEMO-TO-PROGRAM","line_start":604,"line_end":604,"attributes":{"source":"WS-PGM-AUTH-SMRY","targets":"CDEMO-TO-PROGRAM"},"children":[]},{"type":"PERFORM","text":"PERFORM RETURN-TO-PREV-SCREEN","line_start":605,"line_end":605,"attributes":{"target":"RETURN-TO-PREV-SCREEN"},"children":[]},{"type":"ELSE","text":"ELSE","line_start":606,"line_end":635,"children":[{"type":"MOVE","text":"MOVE DFHCOMMAREA(1:EIBCALEN) TO CARDDEMO-COMMAREA","line_start":607,"line_end":607,"attributes":{"source":"DFHCOMMAREA(1:EIBCALEN)","targets":"CARDDEMO-COMMAREA"},"children":[]},{"type":"MOVE","text":"MOVE SPACES TO CDEMO-CPVD-FRAUD-DATA","line_start":608,"line_end":608,"attributes":{"source":"SPACES","targets":"CDEMO-CPVD-FRAUD-DATA"},"children":[]},{"type":"IF","text":"IF NOT CDEMO-PGM-REENTER SET CDEMO-PGM-REENTER TO TRUE PERFORM PROCESS-ENTER-KEY PERFORM SEND-AUTHVIEW-SCREEN ELSE PERFORM RECEIVE-AUTHVIEW-SCREEN EVALUATE EIBAID WHEN DFHENTER PERFORM PROCESS-ENTE...","line_start":609,"line_end":635,"attrib