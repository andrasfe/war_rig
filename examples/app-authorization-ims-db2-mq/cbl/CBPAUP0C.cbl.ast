{"program_id": "CBPAUP0C", "paragraphs": [{"name": "MAIN-PARA", "line_start": 136, "line_end": 180, "statements": [{"type": "PERFORM_THRU", "text": "PERFORM 1000-INITIALIZE                THRU 1000-EXIT", "line_start": 138, "line_end": 138, "attributes": {"target": "1000-INITIALIZE", "thru": "1000-EXIT"}, "children": []}, {"type": "PERFORM_THRU", "text": "PERFORM 2000-FIND-NEXT-AUTH-SUMMARY    THRU 2000-EXIT", "line_start": 140, "line_end": 140, "attributes": {"target": "2000-FIND-NEXT-AUTH-SUMMARY", "thru": "2000-EXIT"}, "children": []}, {"type": "PERFORM_INLINE", "text": "PERFORM UNTIL ERR-FLG-ON OR END-OF-AUTHDB", "line_start": 142, "line_end": 142, "attributes": {"condition": "ERR-FLG-ON OR END-OF-AUTHDB"}, "children": [{"type": "PERFORM_THRU", "text": "PERFORM 3000-FIND-NEXT-AUTH-DTL     THRU 3000-EXIT", "line_start": 144, "line_end": 144, "attributes": {"target": "3000-FIND-NEXT-AUTH-DTL", "thru": "3000-EXIT"}, "children": []}, {"type": "PERFORM_INLINE", "text": "PERFORM UNTIL NO-MORE-AUTHS", "line_start": 146, "line_end": 146, "attributes": {"condition": "NO-MORE-AUTHS"}, "children": [{"type": "PERFORM_THRU", "text": "PERFORM 4000-CHECK-IF-EXPIRED    THRU 4000-EXIT", "line_start": 147, "line_end": 147, "attributes": {"target": "4000-CHECK-IF-EXPIRED", "thru": "4000-EXIT"}, "children": []}, {"type": "IF", "text": "IF QUALIFIED-FOR-DELETE", "line_start": 149, "line_end": 149, "attributes": {"condition": "QUALIFIED-FOR-DELETE"}, "children": [{"type": "PERFORM_THRU", "text": "PERFORM 5000-DELETE-AUTH-DTL  THRU 5000-EXIT", "line_start": 150, "line_end": 150, "attributes": {"target": "5000-DELETE-AUTH-DTL", "thru": "5000-EXIT"}, "children": []}]}, {"type": "PERFORM_THRU", "text": "PERFORM 3000-FIND-NEXT-AUTH-DTL  THRU 3000-EXIT", "line_start": 153, "line_end": 153, "attributes": {"target": "3000-FIND-NEXT-AUTH-DTL", "thru": "3000-EXIT"}, "children": []}]}, {"type": "IF", "text": "IF PA-APPROVED-AUTH-CNT <= 0 AND PA-APPROVED-AUTH-CNT <= 0", "line_start": 156, "line_end": 156, "attributes": {"condition": "PA-APPROVED-AUTH-CNT <= 0 AND PA-APPROVED-AUTH-CNT <= 0"}, "children": [{"type": "PERFORM_THRU", "text": "PERFORM 6000-DELETE-AUTH-SUMMARY THRU 6000-EXIT", "line_start": 157, "line_end": 157, "attributes": {"target": "6000-DELETE-AUTH-SUMMARY", "thru": "6000-EXIT"}, "children": []}]}, {"type": "IF", "text": "IF WS-AUTH-SMRY-PROC-CNT > P-CHKP-FREQ", "line_start": 160, "line_end": 160, "attributes": {"condition": "WS-AUTH-SMRY-PROC-CNT > P-CHKP-FREQ"}, "children": [{"type": "PERFORM_THRU", "text": "PERFORM 9000-TAKE-CHECKPOINT     THRU 9000-EXIT", "line_start": 161, "line_end": 161, "attributes": {"target": "9000-TAKE-CHECKPOINT", "thru": "9000-EXIT"}, "children": []}, {"type": "MOVE", "text": "MOVE 0                         TO WS-AUTH-SMRY-PROC-CNT", "line_start": 163, "line_end": 163, "attributes": {"source": "0", "targets": "WS-AUTH-SMRY-PROC-CNT"}, "children": []}]}, {"type": "PERFORM_THRU", "text": "PERFORM 2000-FIND-NEXT-AUTH-SUMMARY THRU 2000-EXIT", "line_start": 165, "line_end": 165, "attributes": {"target": "2000-FIND-NEXT-AUTH-SUMMARY", "thru": "2000-EXIT"}, "children": []}]}, {"type": "PERFORM_THRU", "text": "PERFORM 9000-TAKE-CHECKPOINT           THRU 9000-EXIT", "line_start": 169, "line_end": 169, "attributes": {"target": "9000-TAKE-CHECKPOINT", "thru": "9000-EXIT"}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY ' '", "line_start": 171, "line_end": 171, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY '*-------------------------------------*'", "line_start": 172, "line_end": 172, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY '# TOTAL SUMMARY READ  :' WS-NO-SUMRY-READ", "line_start": 173, "line_end": 173, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY '# SUMMARY REC DELETED :' WS-NO-SUMRY-DELETED", "line_start": 174, "line_end": 174, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY '# TOTAL DETAILS READ  :' WS-NO-DTL-READ", "line_start": 175, "line_end": 175, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY '# DETAILS REC DELETED :' WS-NO-DTL-DELETED", "line_start": 176, "line_end": 176, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY '*-------------------------------------*'", "line_start": 177, "line_end": 177, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY ' '", "line_start": 178, "line_end": 178, "attributes": {}, "children": []}, {"type": "GOBACK", "text": "GOBACK", "line_start": 180, "line_end": 180, "attributes": {}, "children": []}]}, {"name": "1000-INITIALIZE", "line_start": 183, "line_end": 210, "statements": [{"type": "ACCEPT", "text": "ACCEPT CURRENT-DATE     FROM DATE", "line_start": 186, "line_end": 186, "attributes": {}, "children": []}, {"type": "ACCEPT", "text": "ACCEPT CURRENT-YYDDD    FROM DAY", "line_start": 187, "line_end": 187, "attributes": {}, "children": []}, {"type": "ACCEPT", "text": "ACCEPT PRM-INFO FROM SYSIN", "line_start": 189, "line_end": 189, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'STARTING PROGRAM CBPAUP0C::'", "line_start": 190, "line_end": 190, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY '*-------------------------------------*'", "line_start": 191, "line_end": 191, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'CBPAUP0C PARM RECEIVED :' PRM-INFO", "line_start": 192, "line_end": 192, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'TODAYS DATE            :' CURRENT-YYDDD", "line_start": 193, "line_end": 193, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY ' '", "line_start": 194, "line_end": 194, "attributes": {}, "children": []}, {"type": "IF", "text": "IF P-EXPIRY-DAYS IS NUMERIC", "line_start": 196, "line_end": 196, "attributes": {"condition": "P-EXPIRY-DAYS IS NUMERIC"}, "children": [{"type": "MOVE", "text": "MOVE P-EXPIRY-DAYS     TO WS-EXPIRY-DAYS", "line_start": 197, "line_end": 197, "attributes": {"source": "P-EXPIRY-DAYS", "targets": "WS-EXPIRY-DAYS"}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 198, "line_end": 198, "attributes": {}, "children": [{"type": "MOVE", "text": "MOVE 5                 TO WS-EXPIRY-DAYS", "line_start": 199, "line_end": 199, "attributes": {"source": "5", "targets": "WS-EXPIRY-DAYS"}, "children": []}]}]}, {"type": "IF", "text": "IF P-CHKP-FREQ = SPACES OR 0 OR LOW-VALUES", "line_start": 201, "line_end": 201, "attributes": {"condition": "P-CHKP-FREQ = SPACES OR 0 OR LOW-VALUES"}, "children": [{"type": "MOVE", "text": "MOVE 5                 TO P-CHKP-FREQ", "line_start": 202, "line_end": 202, "attributes": {"source": "5", "targets": "P-CHKP-FREQ"}, "children": []}]}, {"type": "IF", "text": "IF P-CHKP-DIS-FREQ = SPACES OR 0 OR LOW-VALUES", "line_start": 204, "line_end": 204, "attributes": {"condition": "P-CHKP-DIS-FREQ = SPACES OR 0 OR LOW-VALUES"}, "children": [{"type": "MOVE", "text": "MOVE 10                TO P-CHKP-DIS-FREQ", "line_start": 205, "line_end": 205, "attributes": {"source": "10", "targets": "P-CHKP-DIS-FREQ"}, "children": []}]}, {"type": "IF", "text": "IF P-DEBUG-FLAG NOT = 'Y'", "line_start": 207, "line_end": 207, "attributes": {"condition": "P-DEBUG-FLAG NOT = 'Y'"}, "children": [{"type": "MOVE", "text": "MOVE 'N'               TO P-DEBUG-FLAG", "line_start": 208, "line_end": 208, "attributes": {"source": "'N'", "targets": "P-DEBUG-FLAG"}, "children": []}]}]}, {"name": "1000-EXIT", "line_start": 212, "line_end": 213, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 213, "line_end": 213, "attributes": {}, "children": []}]}, {"name": "2000-FIND-NEXT-AUTH-SUMMARY", "line_start": 216, "line_end": 242, "statements": [{"type": "IF", "text": "IF DEBUG-ON", "line_start": 219, "line_end": 219, "attributes": {"condition": "DEBUG-ON"}, "children": [{"type": "DISPLAY", "text": "DISPLAY 'DEBUG: AUTH SMRY READ : ' WS-NO-SUMRY-READ", "line_start": 220, "line_end": 220, "attributes": {}, "children": []}]}, {"type": "EXEC_DLI", "text": "EXEC DLI GN USING PCB(PAUT-PCB-NUM) SEGMENT (PAUTSUM0) INTO (PENDING-AUTH-SUMMARY) END-EXEC", "line_start": 223, "line_end": 226, "attributes": {"raw_text": "EXEC DLI GN USING PCB(PAUT-PCB-NUM) SEGMENT (PAUTSUM0) INTO (PENDING-AUTH-SUMMARY) END-EXEC"}, "children": []}, {"type": "EVALUATE", "text": "EVALUATE DIBSTAT", "line_start": 228, "line_end": 228, "attributes": {"subject": "DIBSTAT"}, "children": [{"type": "WHEN", "text": "WHEN '  '", "line_start": 229, "line_end": 229, "attributes": {"value": "'  '"}, "children": [{"type": "SET", "text": "SET NOT-END-OF-AUTHDB TO TRUE", "line_start": 230, "line_end": 230, "attributes": {}, "children": []}, {"type": "ADD", "text": "ADD 1                 TO WS-NO-SUMRY-READ", "line_start": 231, "line_end": 231, "attributes": {}, "children": []}, {"type": "ADD", "text": "ADD 1                 TO WS-AUTH-SMRY-PROC-CNT", "line_start": 232, "line_end": 232, "attributes": {}, "children": []}, {"type": "MOVE", "text": "MOVE PA-ACCT-ID       TO WS-CURR-APP-ID", "line_start": 233, "line_end": 233, "attributes": {"source": "PA-ACCT-ID", "targets": "WS-CURR-APP-ID"}, "children": []}]}, {"type": "WHEN", "text": "WHEN 'GB'", "line_start": 234, "line_end": 234, "attributes": {"value": "'GB'"}, "children": [{"type": "SET", "text": "SET END-OF-AUTHDB     TO TRUE", "line_start": 235, "line_end": 235, "attributes": {}, "children": []}]}, {"type": "WHEN", "text": "WHEN OTHER", "line_start": 236, "line_end": 236, "attributes": {"value": "OTHER"}, "children": [{"type": "DISPLAY", "text": "DISPLAY 'AUTH SUMMARY READ FAILED  :' DIBSTAT", "line_start": 237, "line_end": 237, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'SUMMARY READ BEFORE ABEND :'\nWS-NO-SUMRY-READ", "line_start": 238, "line_end": 239, "attributes": {}, "children": []}, {"type": "PERFORM", "text": "PERFORM 9999-ABEND", "line_start": 240, "line_end": 240, "attributes": {"target": "9999-ABEND"}, "children": []}]}]}]}, {"name": "2000-EXIT", "line_start": 243, "line_end": 244, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 244, "line_end": 244, "attributes": {}, "children": []}]}, {"name": "3000-FIND-NEXT-AUTH-DTL", "line_start": 248, "line_end": 272, "statements": [{"type": "IF", "text": "IF DEBUG-ON", "line_start": 251, "line_end": 251, "attributes": {"condition": "DEBUG-ON"}, "children": [{"type": "DISPLAY", "text": "DISPLAY 'DEBUG: AUTH DTL READ : ' WS-NO-DTL-READ", "line_start": 252, "line_end": 252, "attributes": {}, "children": []}]}, {"type": "EXEC_DLI", "text": "EXEC DLI GNP USING PCB(PAUT-PCB-NUM) SEGMENT (PAUTDTL1) INTO (PENDING-AUTH-DETAILS) END-EXEC", "line_start": 255, "line_end": 258, "attributes": {"raw_text": "EXEC DLI GNP USING PCB(PAUT-PCB-NUM) SEGMENT (PAUTDTL1) INTO (PENDING-AUTH-DETAILS) END-EXEC"}, "children": []}, {"type": "EVALUATE", "text": "EVALUATE DIBSTAT", "line_start": 259, "line_end": 259, "attributes": {"subject": "DIBSTAT"}, "children": [{"type": "WHEN", "text": "WHEN '  '", "line_start": 260, "line_end": 260, "attributes": {"value": "'  '"}, "children": [{"type": "SET", "text": "SET MORE-AUTHS       TO TRUE", "line_start": 261, "line_end": 261, "attributes": {}, "children": []}, {"type": "ADD", "text": "ADD 1                TO WS-NO-DTL-READ", "line_start": 262, "line_end": 262, "attributes": {}, "children": []}]}, {"type": "WHEN", "text": "WHEN 'GE'", "line_start": 263, "line_end": 263, "attributes": {"value": "'GE'"}, "children": []}, {"type": "WHEN", "text": "WHEN 'GB'", "line_start": 264, "line_end": 264, "attributes": {"value": "'GB'"}, "children": [{"type": "SET", "text": "SET NO-MORE-AUTHS    TO TRUE", "line_start": 265, "line_end": 265, "attributes": {}, "children": []}]}, {"type": "WHEN", "text": "WHEN OTHER", "line_start": 266, "line_end": 266, "attributes": {"value": "OTHER"}, "children": [{"type": "DISPLAY", "text": "DISPLAY 'AUTH DETAIL READ FAILED  :' DIBSTAT", "line_start": 267, "line_end": 267, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'SUMMARY AUTH APP ID      :' PA-ACCT-ID", "line_start": 268, "line_end": 268, "attributes": {}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'DETAIL READ BEFORE ABEND :' WS-NO-DTL-READ", "line_start": 269, "line_end": 269, "attributes": {}, "children": []}, {"type": "PERFORM", "text": "PERFORM 9999-ABEND", "line_start": 270, "line_end": 270, "attributes": {"target": "9999-ABEND"}, "children": []}]}]}]}, {"name": "3000-EXIT", "line_start": 273, "line_end": 274, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 274, "line_end": 274, "attributes": {}, "children": []}]}, {"name": "4000-CHECK-IF-EXPIRED", "line_start": 277, "line_end": 298, "statements": [{"type": "COMPUTE", "text": "COMPUTE WS-AUTH-DATE = 99999 - PA-AUTH-DATE-9C", "line_start": 280, "line_end": 280, "attributes": {"target": "WS-AUTH-DATE", "expression": "99999 - PA-AUTH-DATE-9C"}, "children": []}, {"type": "COMPUTE", "text": "COMPUTE WS-DAY-DIFF = CURRENT-YYDDD - WS-AUTH-DATE", "line_start": 282, "line_end": 282, "attributes": {"target": "WS-DAY-DIFF", "expression": "CURRENT-YYDDD - WS-AUTH-DATE"}, "children": []}, {"type": "IF", "text": "IF WS-DAY-DIFF >= WS-EXPIRY-DAYS", "line_start": 284, "line_end": 284, "attributes": {"condition": "WS-DAY-DIFF >= WS-EXPIRY-DAYS"}, "children": [{"type": "SET", "text": "SET QUALIFIED-FOR-DELETE       TO TRUE", "line_start": 285, "line_end": 285, "attributes": {}, "children": []}, {"type": "IF", "text": "IF PA-AUTH-RESP-CODE = '00'", "line_start": 287, "line_end": 287, "attributes": {"condition": "PA-AUTH-RESP-CODE = '00'"}, "children": [{"type": "SUBTRACT", "text": "SUBTRACT 1                  FROM PA-APPROVED-AUTH-CNT", "line_start": 288, "line_end": 288, "attributes": {}, "children": []}, {"type": "SUBTRACT", "text": "SUBTRACT PA-APPROVED-AMT    FROM PA-APPROVED-AUTH-AMT", "line_start": 289, "line_end": 289, "attributes": {}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 290, "line_end": 290, "attributes": {}, "children": [{"type": "SUBTRACT", "text": "SUBTRACT 1                  FROM PA-DECLINED-AUTH-CNT", "line_start": 291, "line_end": 291, "attributes": {}, "children": []}, {"type": "SUBTRACT", "text": "SUBTRACT PA-TRANSACTION-AMT FROM PA-DECLINED-AUTH-AMT", "line_start": 292, "line_end": 292, "attributes": {}, "children": []}]}]}, {"type": "ELSE", "text": "ELSE", "line_start": 294, "line_end": 294, "attributes": {}, "children": [{"type": "SET", "text": "SET NOT-QUALIFIED-FOR-DELETE   TO TRUE", "line_start": 295, "line_end": 295, "attributes": {}, "children": []}]}]}]}, {"name": "4000-EXIT", "line_start": 299, "line_end": 300, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 300, "line_end": 300, "attributes": {}, "children": []}]}, {"name": "5000-DELETE-AUTH-DTL", "line_start": 303, "line_end": 323, "statements": [{"type": "IF", "text": "IF DEBUG-ON", "line_start": 306, "line_end": 306, "attributes": {"condition": "DEBUG-ON"}, "children": [{"type": "DISPLAY", "text": "DISPLAY 'DEBUG: AUTH DTL DLET : ' PA-ACCT-ID", "line_start": 307, "line_end": 307, "attributes": {}, "children": []}]}, {"type": "EXEC_DLI", "text": "EXEC DLI DLET USING PCB(PAUT-PCB-NUM) SEGMENT (PAUTDTL1) FROM (PENDING-AUTH-DETAILS) END-EXEC", "line_start": 310, "line_end": 313, "attributes": {"raw_text": "EXEC DLI DLET USING PCB(PAUT-PCB-NUM) SEGMENT (PAUTDTL1) FROM (PENDING-AUTH-DETAILS) END-EXEC"}, "children": []}, {"type": "IF", "text": "IF DIBSTAT = SPACES", "line_start": 315, "line_end": 315, "attributes": {"condition": "DIBSTAT = SPACES"}, "children": [{"type": "ADD", "text": "ADD 1                     TO WS-NO-DTL-DELETED", "line_start": 316, "line_end": 316, "attributes": {}, "children": []}, {"type": "ELSE", "text": "ELSE", "line_start": 317, "line_end": 317, "attributes": {}, "children": [{"type": "DISPLAY", "text": "DISPLAY 'AUTH DETAIL DELETE FAILED :' DIBSTAT", "line_start": 31