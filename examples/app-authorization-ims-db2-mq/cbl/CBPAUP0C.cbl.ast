rget": "9999-ABEND"}, "children": []}]}]}]}, {"name": "6000-EXIT", "line_start": 348, "line_end": 349, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 349, "line_end": 349, "attributes": {}, "children": []}]}, {"name": "9000-TAKE-CHECKPOINT", "line_start": 352, "line_end": 372, "statements": [{"type": "EXEC_DLI", "text": "EXEC DLI CHKP ID(WK-CHKPT-ID) END-EXEC", "line_start": 355, "line_end": 356, "attributes": {"raw_text": "EXEC DLI CHKP ID(WK-CHKPT-ID) END-EXEC"}, "children": []}, {"type": "IF", "text": "IF DIBSTAT = SPACES", "line_start": 358, "line_end": 358, "attributes": {"condition": "DIBSTAT = SPACES"}, "children": [{"type": "ADD", "text": "ADD 1                      TO WS-NO-CHKP", "line_start": 359, "line_end": 359, "attributes": {}, "children": []}, {"type": "IF", "text": "IF WS-NO-CHKP >= P-CHKP-DIS-FREQ", "line_start": 360, "line_end": 360, "attributes": {"condition": "WS-NO-CHKP >= P-CHKP-DIS-FREQ"}, "children": [{"type": "MOVE", "text": "MOVE 0                  TO WS-NO-CHKP", "line_start": 361, "line_end": 361, "attributes": {"source": "0", "targets": "WS-NO-CHKP"}, "children": []}, {"type": "DISPLAY", "text": "DISPLAY 'CHKP SUCCESS: AUTH COUNT - ' WS-NO-SUMRY-READ\n', APP ID - ' WS-CURR-APP-ID", "line_start": 362, "line_end": 363, "attributes": {}, "children": []}]}, {"type": "ELSE", "text": "ELSE", "line_start": 365, "line_end": 365, "attributes": {}, "children": [{"type": "DISPLAY", "text": "DISPLAY 'CHKP FAILED: DIBSTAT - ' DIBSTAT\n', REC COUNT - ' WS-NO-SUMRY-READ\n', APP ID - ' WS-CURR-APP-ID", "line_start": 366, "line_end": 368, "attributes": {}, "children": []}, {"type": "PERFORM", "text": "PERFORM 9999-ABEND", "line_start": 369, "line_end": 369, "attributes": {"target": "9999-ABEND"}, "children": []}]}]}]}, {"name": "9000-EXIT", "line_start": 373, "line_end": 374, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 374, "line_end": 374, "attributes": {}, "children": []}]}, {"name": "9999-ABEND", "line_start": 377, "line_end": 383, "statements": [{"type": "DISPLAY", "text": "DISPLAY 'CBPAUP0C ABENDING ...'", "line_start": 380, "line_end": 380, "attributes": {}, "children": []}, {"type": "MOVE", "text": "MOVE 16 TO RETURN-CODE", "line_start": 382, "line_end": 382, "attributes": {"source": "16", "targets": "RETURN-CODE"}, "children": []}, {"type": "GOBACK", "text": "GOBACK", "line_start": 383, "line_end": 383, "attributes": {}, "children": []}]}, {"name": "9999-EXIT", "line_start": 385, "line_end": 386, "statements": [{"type": "EXIT", "text": "EXIT", "line_start": 386, "line_end": 386, "attributes": {}, "children": []}]}]}